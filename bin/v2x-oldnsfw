#!/usr/bin/env bash
# v2x-oldnsfw — restoration pipeline for old/heavily-degraded adult footage
#
# Stages:
#   [A] ffmpeg pre-clean   (yadif deinterlace + hqdn3d light denoise)  → ffv1
#   [B] video2x NMKD-Siax  (denoising 4× upscaler)                     → final
#
# With --deep, B becomes a two-pass: NMKD-Siax does denoise+scale, the
# intermediate is downscaled by 2×, then Remacri does a second pass for
# skin texture on the now-clean image. ~3× the GPU time, marginal gain
# on already-decent sources, real win on truly bad ones.
#
# Final encode is libx265 10-bit CRF 20 yuv420p10le (same as v2x-nsfw).
# Intermediates use FFV1 (lossless) in a tmp dir next to the output.
#
# Usage:
#   v2x-oldnsfw IN OUT [-- extra video2x flags forwarded to all passes]
#   v2x-oldnsfw IN OUT --deep
#   v2x-oldnsfw IN OUT --keep-tmp        # keep intermediates for inspection
set -euo pipefail

DEEP=0
KEEP_TMP=0
NO_CLEAN=0
DUAL=()
ARGS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --deep)       DEEP=1; shift ;;
    --keep-tmp)   KEEP_TMP=1; shift ;;
    --no-clean)   NO_CLEAN=1; shift ;;
    --dual-gpu)   DUAL=( --dual-gpu ); shift ;;
    *)            ARGS+=("$1"); shift ;;
  esac
done
set -- "${ARGS[@]}"

if [[ $# -lt 2 ]]; then
  echo "Usage: $(basename "$0") INPUT OUTPUT [--deep] [--keep-tmp] [--no-clean] [video2x flags...]" >&2
  exit 1
fi
INPUT="$(readlink -f -- "$1")"
OUTPUT="$2"
shift 2
EXTRA=("$@")

[[ -f "$INPUT" ]] || { echo "v2x-oldnsfw: input not found: $INPUT" >&2; exit 1; }

OUT_DIR="$(dirname -- "$OUTPUT")"
mkdir -p -- "$OUT_DIR"
OUT_DIR="$(readlink -f -- "$OUT_DIR")"
STAGE_DIR="$(mktemp -d -p "$OUT_DIR" .v2x-oldnsfw.XXXXXX)"
if [[ $KEEP_TMP -eq 0 ]]; then
  trap 'rm -rf "$STAGE_DIR"' EXIT
else
  trap 'echo "intermediates kept in: $STAGE_DIR"' EXIT
fi

log() { printf '\n→ [%s] %s\n' "$1" "$2"; }

# Stage A: pre-clean with host ffmpeg
if [[ $NO_CLEAN -eq 0 ]]; then
  CLEANED="$STAGE_DIR/cleaned.mkv"
  log "A" "ffmpeg pre-clean (yadif deinterlace + hqdn3d light denoise)"
  ffmpeg -nostdin -hide_banner -loglevel warning -stats -y \
    -i "$INPUT" \
    -vf "yadif=mode=1,hqdn3d=2:1:3:2" \
    -c:v ffv1 -level 3 -threads 8 -c:a copy \
    "$CLEANED"
  SOURCE_FOR_V2X="$CLEANED"
else
  SOURCE_FOR_V2X="$INPUT"
fi

if [[ $DEEP -eq 1 ]]; then
  # Two-pass: denoise+scale → halve → texture pass → final encode
  STAGE1="$STAGE_DIR/stage1-siax.mkv"
  STAGE2="$STAGE_DIR/stage2-half.mkv"

  log "B1" "video2x NMKD-Siax 4× (denoise + scale) → ffv1"
  video2x "${DUAL[@]}" --model nmkd-siax -s 4 -c ffv1 \
    "$SOURCE_FOR_V2X" "$STAGE1" \
    "${EXTRA[@]}"

  log "B2" "ffmpeg downscale to 2× of original"
  ffmpeg -nostdin -hide_banner -loglevel warning -stats -y \
    -i "$STAGE1" \
    -vf "scale=iw/2:ih/2:flags=lanczos" \
    -c:v ffv1 -level 3 -threads 8 -c:a copy \
    "$STAGE2"

  log "C" "video2x Remacri 4× (skin texture pass) → libx265 10-bit"
  video2x "${DUAL[@]}" --model remacri -s 4 -c libx265 \
    "$STAGE2" "$OUTPUT" \
    "${EXTRA[@]}" \
    -- --pix-fmt yuv420p10le -e crf=20 -e preset=slow
else
  # Single-pass: NMKD-Siax 4× directly into final encode
  log "B" "video2x NMKD-Siax 4× → libx265 10-bit"
  video2x "${DUAL[@]}" --model nmkd-siax -s 4 -c libx265 \
    "$SOURCE_FOR_V2X" "$OUTPUT" \
    "${EXTRA[@]}" \
    -- --pix-fmt yuv420p10le -e crf=20 -e preset=slow
fi

printf '\n✓ done: %s\n' "$OUTPUT"
